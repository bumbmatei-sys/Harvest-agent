rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Invoice + receipt PDFs are financial documents — never publicly readable.
    // Written by Cloud Functions (Admin SDK) and downloaded on demand through an
    // authenticated signed-URL endpoint; both bypass these rules, so deny direct access.
    match /tenants/{tenantId}/invoices/{fileName} {
      allow read, write: if false;
    }
    match /tenants/{tenantId}/annual-receipts/{allPaths=**} {
      allow read, write: if false;
    }
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}