# ============================================================
# Harvest — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
#
# SENSITIVE — handle with care:
#   FIREBASE_SERVICE_ACCOUNT  bypasses all Firestore security rules
#   STRIPE_SECRET_KEY         can initiate charges and move money
# ============================================================

# ============================================================
# Firebase — client-side (safe to expose to browser)
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id

# ============================================================
# Firebase — server-side (NEVER expose to browser)
# FIREBASE_SERVICE_ACCOUNT is the full service account JSON as a single-line string.
# Generate at: Firebase Console → Project Settings → Service Accounts → Generate new private key
# ============================================================
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# ============================================================
# Stripe — TEST MODE keys during development
# Get keys at: https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY: NEVER expose to browser
# STRIPE_WEBHOOK_SECRET: from Stripe Dashboard → Webhooks → your endpoint
# Price IDs: from Stripe Dashboard → Products → each plan's price
# ============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription plan prices (monthly / yearly)
STRIPE_PRICE_PLUS_MONTHLY=price_...
STRIPE_PRICE_PLUS_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_MAX_MONTHLY=price_...
STRIPE_PRICE_MAX_YEARLY=price_...
STRIPE_PRICE_ULTRA_MONTHLY=price_...
STRIPE_PRICE_ULTRA_YEARLY=price_...

# Add-on prices
# STRIPE_PRICE_AI_MONTHLY must be a $200/mo recurring price (unit_amount=20000).
# Create in Stripe Dashboard → Products → AI Assistant → Add price → $200/month.
# The original fallback price_1TjKTd1YKkcSbTf3HSrtrxE9 was $100/mo — do NOT use it.
STRIPE_PRICE_AI_MONTHLY=price_...
STRIPE_PRICE_AI_SETUP=price_...

# ============================================================
# AI
# ============================================================
# Gemini — used for embeddings only (RAG pipeline)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# MiMo — used for RAG chat responses (mimo-v2.5 via Token Plan API)
# Base URL: token-plan-cn.xiaomimimo.com
MIMO_API_KEY=tp-...

# ============================================================
# Email — Resend
# Get key at: https://resend.com/api-keys
# Used for: welcome emails, enterprise contact form notifications
# ============================================================
RESEND_API_KEY=re_...

# ============================================================
# Integrations — Composio
# Used for Instagram and Mailchimp OAuth flows
# Get at: https://app.composio.dev/settings
# ============================================================
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_STATE_SECRET=your_composio_state_secret_hex_string

# ============================================================
# Maps — Google
# Used for church location autocomplete (Places API)
# Restrict this key to your domain in Google Cloud Console
# ============================================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================
# Infra — Upstash Redis
# Used for rate limiting in middleware
# Get at: https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ============================================================
# App / Misc
# ============================================================
# Secret for cron-triggered internal routes (canvas cleanup, affiliate retry)
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_secret

# Telegram bot token for the AI Assistant feature (Ultra/Enterprise only)
# Get from @BotFather on Telegram
TELEGRAM_BOT_SECRET=your_telegram_bot_token

# Canonical app URL — used in redirect URLs and email links
NEXT_PUBLIC_APP_URL=https://theharvest.app

# Email address granted super-admin access (bypasses tenant checks)
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=your@email.com

# ============================================================
# Custom Domains (Ministry plan) — Vercel API
# ============================================================
# Used by /api/domains/provision to attach + verify tenant custom domains.
# Create a token at https://vercel.com/account/tokens
VERCEL_API_TOKEN=your_vercel_api_token
# The Vercel project ID that serves the app (Project Settings → General)
VERCEL_PROJECT_ID=your_vercel_project_id
# Optional — only needed if the project lives under a Vercel team
VERCEL_TEAM_ID=your_vercel_team_id
