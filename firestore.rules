rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin or superAdmin via custom claims (set server-side with Firebase Admin SDK)
    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.admin == true ||
         request.auth.token.superAdmin == true);
    }

    // Tenant ID derived from the user's custom claims
    function userTenantId() {
      return request.auth.token.tenantId;
    }

    // Check if the authenticated user belongs to a given tenant
    function belongsToTenant(tenantId) {
      return isAuthenticated() && userTenantId() == tenantId;
    }

    // Admin belonging to the given tenant
    function isTenantAdmin(tenantId) {
      return isAuthenticated() &&
        (request.auth.token.superAdmin == true ||
         (request.auth.token.admin == true && userTenantId() == tenantId));
    }

    // Check if request includes correct tenantId that matches the user's claims
    function requestHasCorrectTenant() {
      return isAuthenticated() &&
        request.resource.data.tenantId == userTenantId();
    }

    // ─── Users ───────────────────────────────────────────────────────

    match /users/{userId} {
      // Users can read only their own document; tenant admins can read users in their tenant; super admins can read all
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId ||
         request.auth.token.superAdmin == true ||
         isTenantAdmin(resource.data.tenantId));

      // Self-registration: user creates their own profile. Block role escalation.
      allow create: if isAuthenticated() && request.auth.uid == userId &&
        (!request.resource.data.keys().hasAny(['role']) ||
         request.resource.data.role == 'user');

      // Users can update own profile; tenant admins can update users in their tenant.
      // BLOCK role changes — only Admin SDK (server-side) can change roles.
      // Uses diff().affectedKeys() to check only changed fields, not full post-write document.
      allow update: if isAuthenticated() &&
        ((request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
         (isTenantAdmin(resource.data.tenantId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])));

      // Only super admins can delete user documents
      allow delete: if isAuthenticated() &&
        request.auth.token.superAdmin == true;
    }

    // ─── Submissions ─────────────────────────────────────────────────

    match /submissions/{subId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Community Posts ─────────────────────────────────────────────

    match /community_posts/{postId} {
      // Any authenticated user can read (client queries already filter by tenantId)
      allow read: if isAuthenticated();

      // Create: must set own authorId and a tenantId matching the user's own tenant
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid &&
        requestHasCorrectTenant();

      // Update: two cases.
      // 1) Interaction fields (likes, poll votes, event attendance) — any
      //    tenant member can change these, since liking/voting/RSVPing
      //    isn't an authoring action. Restricted to ONLY those fields so
      //    this can't be used to rewrite post content.
      // 2) Content edits (title, body, everything else) — author or
      //    tenant admin only.
      allow update: if isAuthenticated() && belongsToTenant(resource.data.tenantId) &&
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes', 'pollOptions', 'eventDetails']) ||
          resource.data.authorId == request.auth.uid ||
          isTenantAdmin(resource.data.tenantId)
        );

      // Delete: author or tenant admin only — not "any authenticated user"
      allow delete: if isAuthenticated() &&
        (resource.data.authorId == request.auth.uid ||
         isTenantAdmin(resource.data.tenantId));

      // ─── Comments subcollection ─────────────────────────────────────
      match /comments/{commentId} {
        // Read: any authenticated user
        allow read: if isAuthenticated();
        // Create: must be own authorId, content ≤280 chars
        allow create: if isAuthenticated() &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 280 &&
          request.resource.data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt']);
        // Delete: author can delete own comments
        allow delete: if isAuthenticated() &&
          resource.data.authorId == request.auth.uid;
        // Comments are immutable
        allow update: if false;
      }
    }


    // ─── Blog Posts ─────────────────────────────────────────────────

    match /blog_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Courses ────────────────────────────────────────────────────

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Churches ───────────────────────────────────────────────────

    match /churches/{churchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);

      // Announcements subcollection — per-church
      match /announcements/{announcementId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.tenantId);
        allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
        allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      }
    }

    // ─── RAG Sources & Chunks ───────────────────────────────────────

    match /rag_sources/{sourceId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isAdmin() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    match /rag_chunks/{chunkId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isAdmin() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Authors & Categories (shared within tenant) ────────────────

    match /authors/{authorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin() && belongsToTenant(resource.data.tenantId);
    }

    match /categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin() && belongsToTenant(resource.data.tenantId);
    }

    // ─── Tenants ────────────────────────────────────────────────────

    match /tenants/{tenantId} {
      // SECURITY: this doc is readable by anyone, including unauthenticated
      // requests — required so the public marketing/login pages can resolve
      // a subdomain to a tenant and show branding before login.
      //
      // KNOWN ISSUE — NOT YET FIXED: stripeCustomerId, stripeSubscriptionId,
      // and addOnAiAssistantCode currently live on this same public document,
      // meaning they are readable by anyone who knows or guesses a tenant ID.
      // The correct fix is to move these three fields to a private
      // subcollection (e.g. tenants/{tenantId}/private/billing) that is
      // readable only by tenant members/admins, and update every read/write
      // site (Stripe checkout, webhook, donate, connect, cancel-addon,
      // update-quantity routes, plus AdminSettings/Onboarding components) to
      // use the new location. This is a multi-file migration, tracked
      // separately — do not attempt as a one-line rule change, since an
      // incomplete migration will silently break checkout/billing.
      allow read: if true;

      // Tenant creation: require essential fields and valid values
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['name', 'subdomain', 'plan', 'status']) &&
        request.resource.data.status in ['active', 'setup', 'pending'];

      // Only tenant admins can update their own tenant
      allow update: if isAuthenticated() && isTenantAdmin(tenantId);

      // Only super admins can delete tenants
      allow delete: if isAuthenticated() &&
        request.auth.token.superAdmin == true;

      // ─── Tenant-scoped subcollections ──────────────────────────────

      match /settings/{settingId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      match /members/{memberId} {
        allow read: if belongsToTenant(tenantId);
        allow create, delete: if isTenantAdmin(tenantId);
        allow update: if belongsToTenant(tenantId) &&
          (request.auth.uid == memberId || isTenantAdmin(tenantId));
      }
    }

    // ─── Docs & Doc Folders ──────────────────────────────────────────

    match /docs/{docId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.createdBy == request.auth.uid);
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || resource.data.createdBy == request.auth.uid);
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /docFolders/{folderId} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin();
    }

    // ─── Events & Registrations ──────────────────────────────────────

    match /tenants/{tenantId}/events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isTenantAdmin(tenantId);
    }

    match /tenants/{tenantId}/registrations/{regId} {
      allow read: if isAuthenticated() && (isTenantAdmin(tenantId) || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isTenantAdmin(tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(tenantId);
    }

    // ─── Fundraising Campaigns ───────────────────────────────────────

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /tenants/{tenantId}/campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow write: if isTenantAdmin(tenantId);
    }

    // ─── CRM Contacts & Activities ───────────────────────────────────

    match /tenants/{tenantId}/contacts/{contactId} {
      allow read: if isTenantAdmin(tenantId);
      allow write: if isTenantAdmin(tenantId);
    }

    match /tenants/{tenantId}/contactActivities/{activityId} {
      allow read: if isTenantAdmin(tenantId);
      allow write: if isTenantAdmin(tenantId);
    }

    // ─── Community Chat ──────────────────────────────────────────────

    match /tenants/{tenantId}/channels/{channelId} {
      allow read: if belongsToTenant(tenantId) || isTenantAdmin(tenantId);
      allow write: if isTenantAdmin(tenantId);
    }

    match /tenants/{tenantId}/channelMessages/{msgId} {
      allow read: if belongsToTenant(tenantId) || isTenantAdmin(tenantId);
      allow create: if belongsToTenant(tenantId) || isTenantAdmin(tenantId);
      allow update, delete: if isTenantAdmin(tenantId);
    }

    match /tenants/{tenantId}/directMessages/{dmId} {
      allow read: if belongsToTenant(tenantId) || isTenantAdmin(tenantId);
      allow create: if isTenantAdmin(tenantId);
      allow update: if isTenantAdmin(tenantId);
      allow delete: if isTenantAdmin(tenantId);
    }

    match /tenants/{tenantId}/dmMessages/{msgId} {
      allow read: if belongsToTenant(tenantId) || isTenantAdmin(tenantId);
      allow create: if belongsToTenant(tenantId) || isTenantAdmin(tenantId);
      allow update, delete: if isTenantAdmin(tenantId);
    }

    // ─── Invoices (for receipt generation) ───────────────────────────

    match /tenants/{tenantId}/invoices/{invoiceId} {
      allow read: if isTenantAdmin(tenantId);
      allow write: if isTenantAdmin(tenantId);
    }

    // ─── Email Log (server-only, but allow authenticated reads) ─────

    match /email_log/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if false; // Only via admin SDK (API routes)
    }

    // ─── Enterprise Leads (server-only writes, admin reads) ────────

    match /enterprise_leads/{leadId} {
      allow read: if isAuthenticated() && request.auth.token.superAdmin == true;
      allow create: if false; // Server-only via API route (has rate limiting + validation)
      allow update, delete: if false; // Server-only via admin SDK
    }

    // ─── Affiliate Commissions (server-only writes, admin reads) ───

    match /affiliate_commissions/{commissionId} {
      allow read: if isAuthenticated() &&
        (request.auth.token.superAdmin == true ||
         resource.data.referrerId == request.auth.uid);
      allow create: if false; // Only via admin SDK (webhook handler)
      allow update: if isAuthenticated() && request.auth.token.superAdmin == true;
      allow delete: if false;
    }

    // ─── Catch-all: DENY everything not matched above ────────────────
  }
}
