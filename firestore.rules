rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function tokenEmail() {
      return request.auth.token.get('email', '');
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.get('superAdmin', false) == true ||
        tokenEmail() in ['bumbmatei@proton.me', 'bumbmatei@zohomail.eu']
      );
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDocExists() ? userData().get('role', 'user') : 'user';
    }

    function userTenantId() {
      return request.auth.token.get('tenantId', null) != null
        ? request.auth.token.get('tenantId', null)
        : (userDocExists() ? userData().get('tenantId', null) : null);
    }

    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.token.get('admin', false) == true ||
        userRole() == 'admin' ||
        userRole() == 'super_admin'
      );
    }

    function inTenantAdminEmails(tenantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
        tokenEmail() in get(/databases/$(database)/documents/tenants/$(tenantId)).data.get('adminEmails', []);
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (isAdmin() && userTenantId() == tenantId) ||
        inTenantAdminEmails(tenantId)
      );
    }

    function belongsToTenant(tenantId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        userTenantId() == tenantId ||
        inTenantAdminEmails(tenantId)
      );
    }

    // The tenant owner is the buyer: tenants/{id}.ownerId, set by the Stripe
    // webhook at tenant creation and immutable thereafter.
    function isTenantOwner(uid, tenantId) {
      return tenantId is string && tenantId.size() > 0
        && exists(/databases/$(database)/documents/tenants/$(tenantId))
        && uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.get('ownerId', '');
    }

    function requestHasCorrectTenant() {
      return isAuthenticated() &&
        (isSuperAdmin() || request.resource.data.tenantId == userTenantId());
    }

    // ─── Per-admin permission flags ──────────────────────────────────
    // users/{uid}.permissions is a MAP of booleans — one flag per admin
    // section (the 23-key catalog in PERMISSION_CATEGORIES,
    // src/components/AnalyticsAndRoles.tsx) plus a `fullAccess` master
    // toggle written by the Roles editor.

    function userPermissions() {
      return userDocExists() ? userData().get('permissions', {}) : {};
    }

    // Admin-feature writes: the tenant owner, super admins, legacy
    // adminEmails-roster admins, and fullAccess admins always pass; any
    // other tenant admin must hold the specific permission flag.
    // Non-admins never pass (isTenantAdmin stays the base check).
    function hasPermission(perm, tenantId) {
      return isAuthenticated() && (
        isSuperAdmin()
        || isTenantOwner(request.auth.uid, tenantId)
        || inTenantAdminEmails(tenantId)
        || (isTenantAdmin(tenantId) && (
              userPermissions().get('fullAccess', false) == true ||
              userPermissions().get(perm, false) == true))
      );
    }

    // Forms went through a permission rename (legacy `seeFormsInbox` →
    // `manageForms`); honor the old flag exactly like the client's
    // normalizePermissions() does, so pre-rename admin docs keep working.
    function hasFormsPermission(tenantId) {
      return hasPermission('manageForms', tenantId)
        || (isTenantAdmin(tenantId) && userPermissions().get('seeFormsInbox', false) == true);
    }

    // ─── Users ───────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId ||
         isSuperAdmin() ||
         isTenantAdmin(resource.data.tenantId));

      allow create: if isAuthenticated() && request.auth.uid == userId &&
        (!request.resource.data.keys().hasAny(['role']) ||
         request.resource.data.role == 'user');

      allow update: if isAuthenticated() && (
        // Self-edit: not your own role, permissions, tenantId or plan (privilege /
        // tenant-hopping surface — those change only via admin flows or server
        // routes), and not any affiliate payout/status field (affiliate fields are
        // server-authority — /api/affiliate/* via Admin SDK).
        (request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role', 'permissions', 'tenantId', 'plan',
            'affiliateStripeAccountId', 'affiliateConnectStatus',
            'affiliateEarnings', 'affiliatePendingPayouts', 'affiliateCode'
          ])) ||
        // Tenant admins manage their own tenant's members: role may only be set to
        // 'user' or 'admin' (never 'super_admin'); tenantId/plan are immutable here
        // (an admin must not move a member between tenants — membership is set at
        // creation and otherwise server-only); affiliate fields stay server-only.
        // Changing role/permissions additionally requires the manageAdmins
        // permission (the Roles screen's gate) — otherwise ANY limited admin
        // could escalate themselves or others to full access with one write.
        (isTenantAdmin(resource.data.tenantId) &&
          (!request.resource.data.keys().hasAny(['role']) ||
           request.resource.data.role in ['user', 'admin']) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'tenantId', 'plan',
            'affiliateStripeAccountId', 'affiliateConnectStatus',
            'affiliateEarnings', 'affiliatePendingPayouts', 'affiliateCode'
          ]) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions']) ||
           hasPermission('manageAdmins', resource.data.tenantId))) ||
        isSuperAdmin()
      ) && (
        // Owner protection: the tenant owner's role & permissions are immutable within
        // the tenant — nobody (not even the owner, not another Full Access admin) may
        // change them. Only a platform super admin can. The owner loses admin access
        // solely by cancelling the subscription (handled server-side).
        isSuperAdmin()
        || !isTenantOwner(userId, resource.data.get('tenantId', ''))
        || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions'])
      );

      allow delete: if isSuperAdmin();
    }

    // ─── AI RAG chat usage (server-only) ─────────────────────────────

    match /chat_usage/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false; // server-only (Admin SDK)
    }

    // ─── Submissions ─────────────────────────────────────────────────

    match /submissions/{subId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Platform Inbox ──────────────────────────────────────────────
    // Contact Support / Feature / Bug reports route here. Anyone signed in can
    // file one; ONLY the platform owner (super admin) may read, triage, or
    // delete them. They never surface to tenant admins.

    match /platform_inbox/{reportId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── Community Posts ─────────────────────────────────────────────

    match /community_posts/{postId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.get('tenantId', ''));

      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid &&
        requestHasCorrectTenant();

      // Members may only touch likes/polls/RSVPs or their own posts; cross-
      // author moderation (edit/delete/pin) is the Posts screen → createPosts.
      allow update: if isAuthenticated() && belongsToTenant(resource.data.tenantId) &&
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes', 'pollOptions', 'eventDetails']) ||
          resource.data.authorId == request.auth.uid ||
          hasPermission('createPosts', resource.data.tenantId)
        );

      allow delete: if isAuthenticated() &&
        (resource.data.authorId == request.auth.uid ||
         hasPermission('createPosts', resource.data.tenantId));

      match /comments/{commentId} {
        allow read: if isAuthenticated() &&
          belongsToTenant(get(/databases/$(database)/documents/community_posts/$(postId)).data.get('tenantId', ''));
        allow create: if isAuthenticated() &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 280 &&
          request.resource.data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt']);
        allow delete: if isAuthenticated() &&
          resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }

    // ─── Prayer Requests ─────────────────────────────────────────────
    // Communal prayer feed, tenant-scoped via a `tenantId` field (mirrors
    // community_posts). Everyone in the tenant can read & "pray" (🙏); authors
    // and tenant admins can delete.

    match /prayer_requests/{prayerId} {
      // Members of the tenant read their own wall; super admins (platform
      // context) may read across tenants. Scoping the read server-side — not
      // just via the client query — keeps one tenant's prayers (and author
      // names) from being read by another tenant via an unfiltered query.
      allow read: if isAuthenticated() && belongsToTenant(resource.data.tenantId);

      // Create: author must be the signed-in user, correct tenant, request <= 200 chars.
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && requestHasCorrectTenant()
        && request.resource.data.request is string
        && request.resource.data.request.size() <= 200;

      // Update: only the prayedBy array may change (the 🙏 toggle), within the tenant.
      allow update: if isAuthenticated()
        && belongsToTenant(resource.data.tenantId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedBy']);

      // Delete: author or tenant admin.
      allow delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid
            || isTenantAdmin(resource.data.tenantId));
    }

    // ─── Blog Posts ─────────────────────────────────────────────────

    match /blog_posts/{postId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && hasPermission('writeArticles', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && hasPermission('writeArticles', resource.data.tenantId);
      allow delete: if isAuthenticated() && hasPermission('writeArticles', resource.data.tenantId);
    }

    // ─── Courses ────────────────────────────────────────────────────

    match /courses/{courseId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && hasPermission('createCourses', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && hasPermission('createCourses', resource.data.tenantId);
      allow delete: if isAuthenticated() && hasPermission('createCourses', resource.data.tenantId);
    }

    // ─── Churches ───────────────────────────────────────────────────

    match /churches/{churchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('modifyChurches', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && hasPermission('modifyChurches', resource.data.tenantId);
      allow delete: if isAuthenticated() && hasPermission('modifyChurches', resource.data.tenantId);

      match /announcements/{announcementId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && hasPermission('modifyChurches', request.resource.data.tenantId);
        allow update: if isAuthenticated() && hasPermission('modifyChurches', resource.data.tenantId);
        allow delete: if isAuthenticated() && hasPermission('modifyChurches', resource.data.tenantId);
      }
    }

    // ─── RAG Sources & Chunks ───────────────────────────────────────

    match /rag_sources/{sourceId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && requestHasCorrectTenant() &&
        hasPermission('uploadRag', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && hasPermission('uploadRag', resource.data.tenantId);
      allow delete: if isAuthenticated() && hasPermission('uploadRag', resource.data.tenantId);
    }

    match /rag_chunks/{chunkId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && requestHasCorrectTenant() &&
        hasPermission('uploadRag', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && hasPermission('uploadRag', resource.data.tenantId);
      allow delete: if isAuthenticated() && hasPermission('uploadRag', resource.data.tenantId);
    }

    // ─── Authors & Categories ────────────────────────────────────────

    // Global course-author/category library, written only by the course
    // editor. Docs carry NO tenantId (the old belongsToTenant(...tenantId)
    // checks could never pass for regular admins), so gate on the writer's
    // own-tenant courses permission instead.
    match /authors/{authorId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('createCourses', userTenantId());
    }

    match /categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('createCourses', userTenantId());
    }

    // ─── Tenants ────────────────────────────────────────────────────

    match /tenants/{tenantId} {
      allow read: if true;

      // Build-on-payment: clients can no longer self-provision tenants. The Stripe
      // webhook (Admin SDK) is the only creator on payment — it bypasses rules —
      // so there is no way to get a church account without paying. Super admins can
      // still create one by hand (AdminTenants). This makes self-provisioning
      // structurally impossible from a client.
      allow create: if isSuperAdmin();

      // plan / status / Stripe / add-on fields are billing authority, written only
      // by the Stripe webhook + billing routes via the Admin SDK. ownerId is owner
      // authority (set once by the webhook; gates owner-only billing routes and the
      // users-rule owner protection) and adminEmails is the admin roster the rules
      // themselves trust — both are server/super-admin-only, or the owner lock could
      // be dodged by rewriting them. The remaining fields (name/config/branding/
      // integrations pointers) are edited only by the Branding and Settings
      // screens, so the update additionally requires one of those permissions
      // (owner / fullAccess / adminEmails-roster admins pass via hasPermission).
      // Super admins (platform tenant mgmt) are unrestricted.
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        ((hasPermission('manageBranding', tenantId) || hasPermission('manageSettings', tenantId)) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
           'plan', 'status', 'ownerId', 'adminEmails',
           'stripeCustomerId', 'stripeSubscriptionId', 'stripePriceId',
           'addOnAiAssistant', 'addOnAiAssistantCode', 'aiAssistantSubscriptionItemId'
         ]))
      );

      allow delete: if isSuperAdmin();

      // Dormant subcollection (no code reads or writes it today — the Settings
      // screen edits fields on the tenant DOC itself). Kept gated so it can't
      // become an ungoverned write surface.
      match /settings/{settingId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if hasPermission('manageSettings', tenantId);
      }

      // NOTE: a tenants/{t}/members subcollection block used to live here, but
      // nothing in the app ever reads or writes it (chat "members" is an array
      // field on channel docs; people records live in /users) — removed so the
      // dead allow isn't a residual write surface. Default deny applies.

      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('manageEvents', tenantId);
      }

      match /registrations/{regId} {
        allow read: if isAuthenticated() && (isTenantAdmin(tenantId) || resource.data.userId == request.auth.uid);
        allow create: if isAuthenticated() && belongsToTenant(tenantId) &&
          request.resource.data.get('userId', '') == request.auth.uid;
        allow update: if isAuthenticated() && hasPermission('manageEvents', tenantId);
        allow delete: if isAuthenticated() && hasPermission('manageEvents', tenantId);
      }

      // NOTE: a tenants/{t}/campaigns block used to live here, but fundraising
      // campaigns are the TOP-LEVEL /campaigns collection — no code references
      // this subcollection, so the dead allow was removed. Default deny applies.

      match /contacts/{contactId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageCRM', tenantId);
      }

      match /contactActivities/{activityId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageCRM', tenantId);
      }

      // Automated SEO blog scheduling settings (single 'settings' doc).
      // Managed from the Blog screen; all live traffic goes through the
      // /api/blog/automate routes (Admin SDK), so this only gates any
      // direct client access.
      match /blogAutomation/{doc} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('writeArticles', tenantId);
      }

      match /channels/{channelId} {
        allow read: if belongsToTenant(tenantId);
        // Channel management (create/roster/edit) is the Community screen.
        allow write: if hasPermission('manageCommunity', tenantId);
        // Members may update only the last-message preview fields when they post.
        allow update: if belongsToTenant(tenantId) &&
          request.auth.uid in resource.data.get('members', []) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']);
      }

      match /channelMessages/{msgId} {
        // Community admins read/write everything; members read AND post only
        // in channels they belong to (that branch must stay permission-free).
        allow read: if belongsToTenant(tenantId) && (
          isTenantAdmin(tenantId) ||
          request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/channels/$(resource.data.channelId)).data.get('members', [])
        );
        allow create: if belongsToTenant(tenantId) && (
          hasPermission('manageCommunity', tenantId) ||
          request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/channels/$(request.resource.data.channelId)).data.get('members', [])
        );
        allow update, delete: if hasPermission('manageCommunity', tenantId);
      }

      match /directMessages/{dmId} {
        allow read: if belongsToTenant(tenantId);
        // Any member may open a thread and any participant reply updates the
        // lastMessage preview (UserMessages) — keep create/update member-level.
        allow create: if belongsToTenant(tenantId);
        allow update: if belongsToTenant(tenantId);
        // No delete UI exists; don't leave thread deletion open to any member.
        allow delete: if hasPermission('manageCommunity', tenantId);
      }

      match /dmMessages/{msgId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId);
        // A recipient may mark a message they DIDN'T send as read (only the `read`
        // flag) — this is what lets a member's DM read-receipt write succeed.
        // Edits / deletes remain admin-only (Community screen → manageCommunity).
        allow update: if hasPermission('manageCommunity', tenantId) || (
          belongsToTenant(tenantId) &&
          resource.data.senderId != request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        );
        allow delete: if hasPermission('manageCommunity', tenantId);
      }

      match /invoices/{invoiceId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageAccounting', tenantId);
      }

      match /newsletters/{newsletterId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageNewsletter', tenantId);
      }

      match /givingStatements/{statementId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageGivingStatements', tenantId);
      }

      // Pledge campaign commitments — admins manage; public pledge submissions
      // are written server-side via the admin SDK (/api/pledge/submit), so client
      // access stays admin-only here.
      match /pledges/{pledgeId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageFundraising', tenantId);
      }

      // Custom forms — admins manage (write) forms; any tenant member may read
      // form metadata so forms can be attached in channel/DM messages and opened.
      // Form content is public anyway (rendered on the no-auth /form/{id} page).
      // Submissions remain admin-only (read server-side via the admin SDK).
      match /forms/{formId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if hasFormsPermission(tenantId);

        match /submissions/{submissionId} {
          allow read: if isTenantAdmin(tenantId);
          allow write: if hasFormsPermission(tenantId);
        }
      }

      // Check-in sessions — admins manage; public check-ins are written
      // server-side via the admin SDK (/api/checkin/submit), so client access
      // stays admin-only here. (The QR sub-tab is a pure generator — it never
      // writes sessions — so manageQR does not grant session writes.)
      match /checkinSessions/{sessionId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageCheckin', tenantId);

        match /attendees/{attendeeId} {
          allow read: if isTenantAdmin(tenantId);
          allow write: if hasPermission('manageCheckin', tenantId);
        }
      }

      // Livestream — viewers read the current stream doc; admins manage streams.
      // Viewer counts + prayers are written server-side via the admin SDK
      // (/api/livestream/*), so client writes stay admin-only.
      match /livestream/{docId} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('manageLivestream', tenantId);
        // Notes → "Share to Livestream" (AdminDocs) writes ONLY sermonNote and
        // is gated by manageDocs, not manageLivestream — allow that single
        // field for docs admins so the cross-screen flow keeps working.
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sermonNote'])
          && hasPermission('manageDocs', tenantId);
      }

      match /livestreamSessions/{sessionId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageLivestream', tenantId);

        match /prayers/{prayerId} {
          allow read: if isTenantAdmin(tenantId);
          allow write: if hasPermission('manageLivestream', tenantId);
        }
      }

      // SMS broadcasts + logs — admin-only. Sends happen server-side via the
      // admin SDK (/api/sms/*); admins read history client-side.
      match /smsBroadcasts/{broadcastId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageSms', tenantId);

        match /logs/{logId} {
          allow read: if isTenantAdmin(tenantId);
          allow write: if hasPermission('manageSms', tenantId);
        }
      }

      match /smsLogs/{logId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if hasPermission('manageSms', tenantId);
      }
    }

    // ─── Docs & Doc Folders ───────────────────────────────────────────

    match /docs/{docId} {
      allow read: if isAuthenticated() &&
        (isTenantAdmin(resource.data.get('tenantId', '')) ||
         resource.data.get('createdBy', '') == request.auth.uid ||
         request.auth.uid in resource.data.get('sharedWith', []));
      allow create: if isAuthenticated() && hasPermission('manageDocs', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() &&
        (hasPermission('manageDocs', resource.data.get('tenantId', '')) || resource.data.get('createdBy', '') == request.auth.uid);
      allow delete: if isAuthenticated() && hasPermission('manageDocs', resource.data.get('tenantId', ''));
    }

    match /docFolders/{folderId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && hasPermission('manageDocs', request.resource.data.get('tenantId', ''));
      allow update, delete: if isAuthenticated() && hasPermission('manageDocs', resource.data.get('tenantId', ''));
    }

    // ─── Fundraising Campaigns ───────────────────────────────────────

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && hasPermission('manageFundraising', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && hasPermission('manageFundraising', resource.data.get('tenantId', ''));
      allow delete: if isAuthenticated() && hasPermission('manageFundraising', resource.data.get('tenantId', ''));
    }

    // ─── CRM Contacts & Activities ───────────────────────────────────

    match /contacts/{contactId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && hasPermission('manageCRM', request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && hasPermission('manageCRM', resource.data.get('tenantId', ''));
      allow delete: if isAuthenticated() && hasPermission('manageCRM', resource.data.get('tenantId', ''));
    }

    match /contactActivities/{activityId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && hasPermission('manageCRM', request.resource.data.get('tenantId', ''));
      allow update, delete: if isAuthenticated() && hasPermission('manageCRM', resource.data.get('tenantId', ''));
    }

    // ─── Donations ───────────────────────────────────────────────────

    // Legacy/dead collection — nothing in the app reads or writes it (donation
    // records live as tenants/{t}/invoices docs of type 'donation_receipt').
    // The old update/delete rule used the UNSCOPED isAdmin(), letting any
    // tenant's admin edit any donation doc cross-tenant; locked to super admin.
    match /donations/{donationId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    // ─── Email Log ───────────────────────────────────────────────────

    match /email_log/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if false;
    }

    // ─── Enterprise Leads ────────────────────────────────────────────

    match /enterprise_leads/{leadId} {
      allow read: if isSuperAdmin();
      allow create: if false;
      allow update, delete: if false;
    }

    // ─── Affiliate Commissions ───────────────────────────────────────

    match /affiliate_commissions/{commissionId} {
      allow read: if isAuthenticated() &&
        (isSuperAdmin() ||
         resource.data.referrerId == request.auth.uid);
      allow create: if false;
      allow update: if isSuperAdmin();
      allow delete: if false;
    }
  }
}
