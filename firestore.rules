rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function tokenEmail() {
      return request.auth.token.get('email', '');
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.get('superAdmin', false) == true ||
        tokenEmail() in ['bumbmatei@proton.me', 'bumbmatei@zohomail.eu']
      );
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDocExists() ? userData().get('role', 'user') : 'user';
    }

    function userTenantId() {
      return request.auth.token.get('tenantId', null) != null
        ? request.auth.token.get('tenantId', null)
        : (userDocExists() ? userData().get('tenantId', null) : null);
    }

    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.token.get('admin', false) == true ||
        userRole() == 'admin' ||
        userRole() == 'super_admin'
      );
    }

    function inTenantAdminEmails(tenantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
        tokenEmail() in get(/databases/$(database)/documents/tenants/$(tenantId)).data.get('adminEmails', []);
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (isAdmin() && userTenantId() == tenantId) ||
        inTenantAdminEmails(tenantId)
      );
    }

    function belongsToTenant(tenantId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        userTenantId() == tenantId ||
        inTenantAdminEmails(tenantId)
      );
    }

    function requestHasCorrectTenant() {
      return isAuthenticated() &&
        (isSuperAdmin() || request.resource.data.tenantId == userTenantId());
    }

    // ─── Users ───────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId ||
         isSuperAdmin() ||
         isTenantAdmin(resource.data.tenantId));

      allow create: if isAuthenticated() && request.auth.uid == userId &&
        (!request.resource.data.keys().hasAny(['role']) ||
         request.resource.data.role == 'user');

      allow update: if isAuthenticated() &&
        // Users may edit their own doc but not their own role.
        ((request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
         // Tenant admins (and super admins) may manage members of their tenant,
         // including promoting/demoting role and editing permissions.
         isTenantAdmin(resource.data.tenantId));

      allow delete: if isSuperAdmin();
    }

    // ─── Submissions ─────────────────────────────────────────────────

    match /submissions/{subId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Community Posts ─────────────────────────────────────────────

    match /community_posts/{postId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid &&
        requestHasCorrectTenant();

      allow update: if isAuthenticated() && belongsToTenant(resource.data.tenantId) &&
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes', 'pollOptions', 'eventDetails']) ||
          resource.data.authorId == request.auth.uid ||
          isTenantAdmin(resource.data.tenantId)
        );

      allow delete: if isAuthenticated() &&
        (resource.data.authorId == request.auth.uid ||
         isTenantAdmin(resource.data.tenantId));

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 280 &&
          request.resource.data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt']);
        allow delete: if isAuthenticated() &&
          resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }

    // ─── Blog Posts ─────────────────────────────────────────────────

    match /blog_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Courses ────────────────────────────────────────────────────

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Churches ───────────────────────────────────────────────────

    match /churches/{churchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);

      match /announcements/{announcementId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.tenantId);
        allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
        allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      }
    }

    // ─── RAG Sources & Chunks ───────────────────────────────────────

    match /rag_sources/{sourceId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isAdmin() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    match /rag_chunks/{chunkId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isAdmin() && requestHasCorrectTenant();
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }

    // ─── Authors & Categories ────────────────────────────────────────

    match /authors/{authorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin() &&
        (isSuperAdmin() || belongsToTenant(request.resource.data.tenantId) || belongsToTenant(resource.data.tenantId));
    }

    match /categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin() &&
        (isSuperAdmin() || belongsToTenant(request.resource.data.tenantId) || belongsToTenant(resource.data.tenantId));
    }

    // ─── Tenants ────────────────────────────────────────────────────

    match /tenants/{tenantId} {
      allow read: if true;

      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['name', 'subdomain', 'plan', 'status']) &&
        request.resource.data.status in ['active', 'setup', 'pending'];

      allow update: if isAuthenticated() && isTenantAdmin(tenantId);

      allow delete: if isSuperAdmin();

      match /settings/{settingId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      match /members/{memberId} {
        allow read: if belongsToTenant(tenantId);
        allow create, delete: if isTenantAdmin(tenantId);
        allow update: if belongsToTenant(tenantId) &&
          (request.auth.uid == memberId || isTenantAdmin(tenantId));
      }

      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }

      match /registrations/{regId} {
        allow read: if isAuthenticated() && (isTenantAdmin(tenantId) || resource.data.userId == request.auth.uid);
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && isTenantAdmin(tenantId);
        allow delete: if isAuthenticated() && isTenantAdmin(tenantId);
      }

      match /campaigns/{campaignId} {
        allow read: if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }

      match /contacts/{contactId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      match /contactActivities/{activityId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      match /channels/{channelId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if isTenantAdmin(tenantId);
        // Members may update only the last-message preview fields when they post.
        allow update: if belongsToTenant(tenantId) &&
          request.auth.uid in resource.data.get('members', []) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']);
      }

      match /channelMessages/{msgId} {
        // Tenant admins read/write everything; members read AND post only in
        // channels they belong to.
        allow read: if belongsToTenant(tenantId) && (
          isTenantAdmin(tenantId) ||
          request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/channels/$(resource.data.channelId)).data.get('members', [])
        );
        allow create: if belongsToTenant(tenantId) && (
          isTenantAdmin(tenantId) ||
          request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/channels/$(request.resource.data.channelId)).data.get('members', [])
        );
        allow update, delete: if isTenantAdmin(tenantId);
      }

      match /directMessages/{dmId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId);
        allow update, delete: if belongsToTenant(tenantId);
      }

      match /dmMessages/{msgId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId);
        // A recipient may mark a message they DIDN'T send as read (only the `read`
        // flag) — this is what lets a member's DM read-receipt write succeed.
        // Edits / deletes remain admin-only.
        allow update: if isTenantAdmin(tenantId) || (
          belongsToTenant(tenantId) &&
          resource.data.senderId != request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        );
        allow delete: if isTenantAdmin(tenantId);
      }

      match /invoices/{invoiceId} {
        allow read, write: if isTenantAdmin(tenantId);
      }

      match /newsletters/{newsletterId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      match /givingStatements/{statementId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Custom forms — admins manage (write) forms; any tenant member may read
      // form metadata so forms can be attached in channel/DM messages and opened.
      // Form content is public anyway (rendered on the no-auth /form/{id} page).
      // Submissions remain admin-only (read server-side via the admin SDK).
      match /forms/{formId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if isTenantAdmin(tenantId);

        match /submissions/{submissionId} {
          allow read, write: if isTenantAdmin(tenantId);
        }
      }

      // Check-in sessions — admins manage; public check-ins are written
      // server-side via the admin SDK (/api/checkin/submit), so client access
      // stays admin-only here.
      match /checkinSessions/{sessionId} {
        allow read, write: if isTenantAdmin(tenantId);

        match /attendees/{attendeeId} {
          allow read, write: if isTenantAdmin(tenantId);
        }
      }

      // Livestream — viewers read the current stream doc; admins manage streams.
      // Viewer counts + prayers are written server-side via the admin SDK
      // (/api/livestream/*), so client writes stay admin-only.
      match /livestream/{docId} {
        allow read: if isAuthenticated();
        allow write: if isTenantAdmin(tenantId);
      }

      match /livestreamSessions/{sessionId} {
        allow read, write: if isTenantAdmin(tenantId);

        match /prayers/{prayerId} {
          allow read, write: if isTenantAdmin(tenantId);
        }
      }

      // SMS broadcasts + logs — admin-only. Sends happen server-side via the
      // admin SDK (/api/sms/*); admins read history client-side.
      match /smsBroadcasts/{broadcastId} {
        allow read, write: if isTenantAdmin(tenantId);

        match /logs/{logId} {
          allow read, write: if isTenantAdmin(tenantId);
        }
      }

      match /smsLogs/{logId} {
        allow read, write: if isTenantAdmin(tenantId);
      }
    }

    // ─── Docs & Doc Folders ───────────────────────────────────────────

    match /docs/{docId} {
      allow read: if isAuthenticated() &&
        (isTenantAdmin(resource.data.get('tenantId', '')) ||
         resource.data.get('createdBy', '') == request.auth.uid ||
         request.auth.uid in resource.data.get('sharedWith', []));
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() &&
        (isTenantAdmin(resource.data.get('tenantId', '')) || resource.data.get('createdBy', '') == request.auth.uid);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
    }

    match /docFolders/{folderId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update, delete: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
    }

    // ─── Fundraising Campaigns ───────────────────────────────────────

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
    }

    // ─── CRM Contacts & Activities ───────────────────────────────────

    match /contacts/{contactId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
    }

    match /contactActivities/{activityId} {
      allow read: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.get('tenantId', ''));
      allow update, delete: if isAuthenticated() && isTenantAdmin(resource.data.get('tenantId', ''));
    }

    // ─── Donations ───────────────────────────────────────────────────

    match /donations/{donationId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ─── Email Log ───────────────────────────────────────────────────

    match /email_log/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if false;
    }

    // ─── Enterprise Leads ────────────────────────────────────────────

    match /enterprise_leads/{leadId} {
      allow read: if isSuperAdmin();
      allow create: if false;
      allow update, delete: if false;
    }

    // ─── Affiliate Commissions ───────────────────────────────────────

    match /affiliate_commissions/{commissionId} {
      allow read: if isAuthenticated() &&
        (isSuperAdmin() ||
         resource.data.referrerId == request.auth.uid);
      allow create: if false;
      allow update: if isSuperAdmin();
      allow delete: if false;
    }
  }
}
